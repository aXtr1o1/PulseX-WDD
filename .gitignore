# ============================================================
# PulseX-WDD — .gitignore
# ============================================================

# ── Secrets & environment ────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
.venv-py311/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Node / Next.js ───────────────────────────────────────────
node_modules/
app/frontend/.next/
app/frontend/out/
app/frontend/.cache/
app/frontend/build/
*.tsbuildinfo
.npm/
.eslintcache

# ── Generated retrieval indices (heavy — rebuild with build_index.py) ──
indices/
*.faiss
*.index

# ── Large binary assets (brochures, raw PDFs — store in cloud/LFS) ──
KB-Acq/raw/
KB-Acq/projectBrochures/
KB-Acq/outputs/
KB-Acq/logs/
KB-Acq/*.pdf
*.pdf

# ── Knowledge Base lifecycle (backups and processed versions) ──
engine-KB/backups/
engine-KB/processed/

# ── Runtime CSV data (live data, never commit) ───────────────
# runtime/leads.csv
# runtime/audit.csv
# runtime/sessions.csv
# Keep: runtime/leads_seed.csv (demo seed data — intentional)

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
pip-log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS cruft ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ── IDE / editor ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.cursor/

# ── Docker ───────────────────────────────────────────────────
.docker/
docker-volumes/

**/node_modules/
# ============================================================
# PulseX-WDD — Environment Variables Example
# Copy to .env and fill in your values
# DO NOT commit .env to version control
# ============================================================


# ── LLM PROVIDER ────────────────────────────────────────────
LLM_PROVIDER=azure_openai

# ── AZURE OPENAI ─────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002

# ── STANDARD OPENAI (alternative) ───────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1  # optional
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ── AZURE DOCUMENT INTELLIGENCE (optional) ──────────────────
AZURE_DOCINTEL_ENDPOINT=https://YOUR_DOCINTEL.cognitiveservices.azure.com
AZURE_DOCINTEL_KEY=YOUR_DOCINTEL_KEY
AZURE_DOCINTEL_API_VERSION=2023-10-31-preview

# ── ADMIN AUTH ───────────────────────────────────────────────
# Required: set a strong password for the admin dashboard
ADMIN_PASSWORD=changeme_use_strong_password

# ── APP CONFIG ───────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── KB / RAG ─────────────────────────────────────────────────
KB_BASE_PATH=engine-KB
KB_TOP_K=5
KB_SIMILARITY_THRESHOLD=0.72
INDEX_REBUILD_ON_START=false

# ── RUNTIME ──────────────────────────────────────────────────
RUNTIME_DIR=runtime

# ── BRAND ────────────────────────────────────────────────────
WDD_BRAND_PRIMARY=#CB2030

# ── LEAD SCORING ─────────────────────────────────────────────
LEAD_SCORING_ENABLED=true
LEAD_SCORE_THRESHOLD_HOT=80
LEAD_SCORE_THRESHOLD_WARM=50

# ── MULTILINGUAL ─────────────────────────────────────────────
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ar

# ── FRONTEND (Next.js) ───────────────────────────────────────
# These go in app/frontend/.env.local (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_API_BASE_URL=https://pulse.axtr.in
NEXT_PUBLIC_WIDGET_BASE_URL=http://localhost:3000
